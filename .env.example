# --- Analytics ---
# Vercel Analytics works automatically when deployed on Vercel — no env vars needed.

# Optional: Google Analytics (GA4)
NEXT_PUBLIC_GA_ID=

# --- Contact form email (optional) ---
# Used in src/app/api/contact/route.ts if you enable the Resend integration
RESEND_API_KEY=

# --- Private analytics dashboard (/dashboard) ---
# Required: sets the password for /dashboard.
ANALYTICS_PASSWORD=

# Optional but recommended for production: Upstash Redis (free tier at
# https://upstash.com) so dashboard data persists across deploys and
# serverless instances. Without these, events are stored in-memory and
# may reset between requests on Vercel.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
